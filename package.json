{
  "name": "bookbuddy",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node node_modules/expo/bin/cli start",
    "android": "node node_modules/expo/bin/cli start --android",
    "ios": "node node_modules/expo/bin/cli start --ios",
    "web": "node node_modules/expo/bin/cli start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|@sentry/.*)"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/newsreader": "^0.4.1",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@sentry/react-native": "^8.11.1",
    "expo": "~55.0.0",
    "expo-asset": "~55.0.0",
    "expo-audio": "~55.0.0",
    "expo-blur": "~55.0.14",
    "expo-dev-client": "~55.0.0",
    "expo-document-picker": "~55.0.0",
    "expo-file-system": "~55.0.0",
    "expo-font": "~55.0.0",
    "expo-location": "~55.0.0",
    "expo-modules-core": "~55.0.0",
    "expo-sharing": "~55.0.0",
    "expo-sqlite": "~55.0.0",
    "expo-status-bar": "~55.0.0",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "typescript": "~5.3.3"
  },
  "private": true
}
